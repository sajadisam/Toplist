generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model server {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  link        String
  tags        String[]
  image       String?
  banner      String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  vote        vote[]
}

model vote {
  id         Int      @id @default(autoincrement())
  vote_count Int
  created_at DateTime @default(now())
  server_id  Int
  server     server   @relation(fields: [server_id], references: [id])
}
